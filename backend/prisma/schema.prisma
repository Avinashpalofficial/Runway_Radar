generator client {
    provider = "prisma-client-js"
}
datasource  db {
    provider = "postgresql"
}

model User {                                   
     id             String   @id @default(uuid())
  name              String
  email             String   @unique
  phoneNumber       String   @unique
  password          String

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions     Subscription[]
  expenses          Expense[]
  financialProfile  FinancialProfile?

  @@index([email])
}
model Subscription {
    id          String       @id @default(uuid())
  name          String
  price         Decimal
  currency      String

  billingType   BillingType  @default(MONTHLY)
  status        Status       @default(ACTIVE)

  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}
model Expense {
     id        String   @id @default(uuid())
  title     String
  amount    Decimal
  currency  String
  category  String?

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
model FinancialProfile{
     id             String   @id @default(uuid())

  cashAvailable  Decimal
  monthlyBurn    Decimal?

  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt      DateTime @updatedAt
}

enum  BillingType{
       MONTHLY
       YEARLY
}
enum Status{
    ACTIVE
    CANCELLED
}