generator client {
    provider = "prisma-client-js"
}
datasource  db {
    provider = "postgresql"
}

model User {                                   
     id                                               String               @id @default(uuid())
     name                                             String
     email                                            String               @unique
     phoneNumber                                      String               @unique
     password                                         String
     createdAt                                        DateTime             @default(now())
     updatedAt                                        DateTime             @updatedAt
     subscription                                     Subscription[]
     expenses                                         Expense[]
}
model Subscription {
    id                                                String               @id @default(uuid())
    name                                              String
    price                                             Float
    currency                                          String
    billingType                                       BillingType          @default(MONTHLY)
    status                                            Status               @default(ACTIVE)
    userId                                            String
    user                                              User                 @relation(fields: [userId],references: [id],onDelete: Cascade)
    createdAt                                         DateTime             @default(now())
    updatedAt                                         DateTime             @updatedAt
}
model Expense {
      id                                              String               @id    @default(uuid())
      title                                           String 
      amount                                          Float
      currency                                        String
      category                                        String?
      userId                                          String
      user                                            User                 @relation(fields: [userId],references: [id],onDelete: Cascade)
      createdAt                                       DateTime             @default(now())
      updateAt                                        DateTime             @updatedAt
}

enum  BillingType{
       MONTHLY
       YEARLY
}
enum Status{
    ACTIVE
    CANCELLED
}